# Copy to .env and fill in (never commit .env)

# Required: SSH password for deploy-remote.sh (sshpass → scp/ssh) / game API VPS
DEPLOY_PASSWORD=

# Optional: value for container RESTART_TOKEN (POST /__netgame/restart).
# If omitted, deploy uses DEPLOY_PASSWORD for the container token as well.
# RESTART_TOKEN=

# ---- Optional: static frontend FTP (different host than API) ----
# If all four are set, deploy-remote.sh uploads ./dist/ after npm run build (mirror --delete
# when lftp is installed; otherwise Python ftplib without deleting remote orphans).
# FTP_HOST=ftp.example.com
# FTP_USER=myuser
# FTP_PASS=secret
# FTP_FOLDER=public_html/netgame
# For FTPS, install lftp and edit deploy-remote.sh (set ftp:ssl-allow / ssl settings).
